{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/myrequests/layout,_N_T_/myrequests/page,_N_T_/myrequests"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/myrequests/__PAGE__",
    "/myrequests",
    "/_index",
    "/_head"
  ]
}
{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/following/layout,_N_T_/following/page,_N_T_/following"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/following/__PAGE__",
    "/following",
    "/_index",
    "/_head"
  ]
}